      "cds:source": { "@id": "https://signed-data.org/sources/api.bcb.gov.br.v1" }
    },
    {
      "@id":          "https://signed-data.org/vocab/finance-brazil/index-igpm",
      "@type":        "rdfs:Class",
      "rdfs:label":   "index.igpm",
      "rdfs:comment": "IGP-M general price index (monthly) from BCB.",
