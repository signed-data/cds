{
  "compilerOptions": {
    "target":                "ES2022",
    "module":                "NodeNext",
    "moduleResolution":      "NodeNext",
    "lib":                   ["ES2022"],
    "types":                 ["node"],
    "outDir":                "./dist",
    "rootDir":               "./src",
    "strict":                true,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess":   false,
    "declaration":           true,
    "declarationMap":        true,
    "sourceMap":             true,
    "esModuleInterop":       true,
    "skipLibCheck":          true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
