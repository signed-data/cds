      "cds:source": { "@id": "https://signed-data.org/sources/api.bcb.gov.br.v1" }
    },
    {
      "@id":          "https://signed-data.org/vocab/finance-brazil/index-ipca",
      "@type":        "rdfs:Class",
      "rdfs:label":   "index.ipca",
      "rdfs:comment": "IPCA consumer price index (monthly and 12-month accumulated) from BCB.",
