  },
  "@graph": [
    {
      "@id":          "https://signed-data.org/vocab/finance-brazil",
      "@type":        "rdfs:Class",
      "rdfs:label":   "finance.brazil",
      "rdfs:comment": "Brazilian financial market data: BCB rates, indices, FX, B3 quotes, and Copom decisions.",
      "rdfs:seeAlso": "https://signed-data.org/spec/domains/finance.brazil"
    },
    {
      "@id":          "https://signed-data.org/vocab/finance-brazil/rate-selic",
      "@type":        "rdfs:Class",
      "rdfs:label":   "rate.selic",
      "rdfs:comment": "SELIC overnight rate from Banco Central do Brasil. Updated daily on business days.",
      "rdfs:subClassOf": { "@id": "https://signed-data.org/vocab/finance-brazil" },
      "cds:source": { "@id": "https://signed-data.org/sources/api.bcb.gov.br.v1" }
    },
    {
      "@id":          "https://signed-data.org/vocab/finance-brazil/rate-cdi",
      "@type":        "rdfs:Class",
      "rdfs:label":   "rate.cdi",
