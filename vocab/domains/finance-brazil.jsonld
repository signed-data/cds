      "cds:source": { "@id": "https://signed-data.org/sources/api.bcb.gov.br.v1" }
    },
    {
      "@id":          "https://signed-data.org/vocab/finance-brazil/fx-usd-brl",
      "@type":        "rdfs:Class",
      "rdfs:label":   "fx.usd-brl",
